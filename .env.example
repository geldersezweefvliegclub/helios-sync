# MQTT broker
MQTT_BROKER_URL=
MQTT_TOPIC=
MQTT_USERNAME=
MQTT_PASSWORD=

# Matrix Synapse
SYNAPSE_URL=
SYNAPSE_ADMIN_USER=
SYNAPSE_ADMIN_PASSWORD=
SYNAPSE_DOMAIN=
SYNAPSE_TOKEN_FILE=
SYNAPSE_ROOMS_CONFIG=

# Helios API — path to credential file (default: helios.account.json)
HELIOS_CREDENTIAL_FILE=./helios.account.json

# Google Gmail service account
# Path to a Google service account JSON with Gmail send permissions
GOOGLE_CREDENTIALS_PATH=./google-sa.json
GOOGLE_ADMIN_EMAIL=noreply@gezc.org

# e-Boekhouden REST API
EB_BASE_URL=https://api.e-boekhouden.nl
EB_ACCESS_TOKEN=
EB_SOURCE=helios

# Cron schedules (default: 03:00 daily, timezone: Europe/Amsterdam)
CRON_EB_BULKSYNC=0 3 * * *
CRON_SYNAPSE_BULKSYNC=5 3 * * *
CRON_TIMEZONE=Europe/Amsterdam

# Logging
LOGGER_SERVER_URL=
LOGGER_API_KEY=
LOGGER_LEVEL=info
INSTANCE=

# Error notification recipient
ICT_EMAIL=

# Set to 'false' to disable email sending (useful during development)
VERZENDEN_EMAIL=true
